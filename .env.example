# Prism Oracle — Environment Configuration
# Set ANTHROPIC_API_KEY for direct API mode (faster, prompt caching, real cost tracking)
# Without it, falls back to claude -p CLI mode
ANTHROPIC_API_KEY=

# Base wallet (agent's wallet for receiving x402 payments)
AGENT_PRIVATE_KEY=
AGENT_WALLET_ADDRESS=

# x402 Configuration
ENABLE_X402=false
X402_FACILITATOR_URL=https://x402.org/facilitator
USE_TESTNET=true

# Server
PORT=3000

# Prism.py path (relative or absolute)
PRISM_PY_PATH=../../prism.py
